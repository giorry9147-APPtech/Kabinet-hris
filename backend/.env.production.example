# Reference for backend production env on Fly.io.
# Real values are set with `fly secrets set KEY=value` — do NOT commit a real .env file.
# Values already encoded in fly.toml [env] block are omitted here.

APP_NAME="Kabinet HRIS"
APP_KEY=                                  # php artisan key:generate --show
APP_URL=https://kabinet-hris-backend.fly.dev
FRONTEND_URL=https://kabinet-hris.vercel.app

# Postgres — DATABASE_URL is auto-injected by `fly postgres attach`,
# entrypoint.sh aliases it to DB_URL for Laravel.
# DB_URL=postgres://user:pass@host:5432/db

CORS_ALLOWED_ORIGINS=https://kabinet-hris.vercel.app
SANCTUM_STATEFUL_DOMAINS=kabinet-hris.vercel.app

# Initial super_admin (SuperAdminSeeder). Change via UI after first login.
ADMIN_EMAIL=admin@kabinet.sr
ADMIN_PASSWORD=change-me-immediately

# Filesystem — for the demo we keep media on the container filesystem (ephemeral
# across deploys). Swap to s3-compat (Cloudflare R2 / Backblaze B2) for persistence.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_BUCKET=
# AWS_DEFAULT_REGION=auto
# AWS_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# AWS_USE_PATH_STYLE_ENDPOINT=true
# FILESYSTEM_DISK=s3
